# ── Backend (Render) ──────────────────────────────────────────────────────────

# Required: Port the Express server listens on (Render sets this automatically)
PORT=10000

# Required: PostgreSQL connection string (Render sets this from the linked DB)
DATABASE_URL=postgresql://user:password@host:5432/price_search

# Search API keys (at least one of Serper or Tavily is needed for searches)
SERPER_API_KEY=
TAVILY_API_KEY=

# Optional: Firecrawl for enhanced page fetching
FIRECRAWL_API_KEY=

# Optional: LLM keys for price extraction
GROQ_API_KEY=
OPENROUTER_KEY=

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────

# Required: Full URL of your Render backend (no trailing slash)
# Example: https://price-search-api.onrender.com
VITE_API_URL=
